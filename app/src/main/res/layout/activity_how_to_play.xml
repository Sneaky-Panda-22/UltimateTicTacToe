<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A1A"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOW TO PLAY"
            android:textSize="11sp"
            android:letterSpacing="0.3"
            android:textColor="#9E9E9E"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ultimate Tic-Tac-Toe"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- ── SECTION JUMP SPINNER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jump to: "
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:layout_marginEnd="8dp" />

        <Spinner
            android:id="@+id/spinnerSection"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/input_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:popupBackground="#FFFFFF" />

    </LinearLayout>

    <!-- ── SCROLLABLE CONTENT ── -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── SECTION 1: BASIC RULES ── -->
            <TextView
                android:id="@+id/sectionBasic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Basic Rules"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:textColor="#9E9E9E"
                android:layout_marginBottom="8dp" />

            <!-- ── SECTION 2: THE SEND RULE ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/card_background"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="The Big Board"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Ultimate Tic-Tac-Toe is played on a 3×3 grid of smaller Tic-Tac-Toe boards. Your goal is to win 3 mini boards in a row — horizontally, vertically, or diagonally."
                    android:textColor="#444444"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Winning a Mini Board"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:text="Win a mini board the same way you'd win regular Tic-Tac-Toe — get 3 of your symbols in a row inside that mini board."
                    android:textColor="#444444"
                    android:textSize="14sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/sectionSendRule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The Send Rule"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:textColor="#9E9E9E"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Where You Play Matters"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="The cell you play inside a mini board determines which mini board your opponent must play in next."
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Example"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="If you play in the top-right cell of any mini board, your opponent must play their next move inside the top-right mini board on the big board."
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Already Won Board"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="If you are sent to a mini board that is already won or drawn, you may play in any open cell on any available mini board."
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- ── SECTION 3: WINNING ── -->
            <TextView
                android:id="@+id/sectionWinning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Winning"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:textColor="#9E9E9E"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Win the Game"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="The first player to win 3 mini boards in a row on the big board wins the game. The winning line can be horizontal, vertical, or diagonal."
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Draw"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="If all 9 mini boards are won or drawn and no player has 3 in a row on the big board, the game is a draw."
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- ── SECTION 4: STRATEGY TIPS ── -->
            <TextView
                android:id="@+id/sectionStrategy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Strategy Tips"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:textColor="#9E9E9E"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Think two moves ahead"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Every move you make sends your opponent somewhere. Use this to trap them in boards you already control."
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Control the center"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Winning the center mini board gives you the most winning line possibilities on the big board."
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Don't ignore small boards"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Letting your opponent win a mini board unchallenged — even a corner one — can cost you the game if it completes their line."
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ── BACK BUTTON AT BOTTOM ── -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="← Back"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1A1A1A"
        android:layout_margin="16dp" />

</LinearLayout>