<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ICTWS-II App Development Mini Project"
            android:textAlignment="center"
            android:textSize="20sp"/>
        <!-- ── HEADER ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="ULTIMATE"
            android:textSize="13sp"
            android:letterSpacing="0.3"
            android:textColor="#9E9E9E"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tic-Tac-Toe"
            android:textSize="38sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="36dp"
            android:text="9 boards. 81 cells. One winner."
            android:textSize="13sp"
            android:textColor="#9E9E9E" />

        <!-- ── DIVIDER ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginBottom="36dp"
            android:background="#1A1A1A" />

        <!-- ── PLAYER 1 CARD ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLAYER 1"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <AutoCompleteTextView
                android:id="@+id/etPlayer1"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Enter name"
                android:textSize="16sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#BDBDBD"
                android:background="@drawable/input_background"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:completionThreshold="1" />

        </LinearLayout>

        <!-- ── PLAYER 2 CARD ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLAYER 2"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <AutoCompleteTextView
                android:id="@+id/etPlayer2"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Enter name"
                android:textSize="16sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#BDBDBD"
                android:background="@drawable/input_background"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:completionThreshold="1" />

        </LinearLayout>

        <!-- ── WHO GOES FIRST ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WHO GOES FIRST"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <RadioGroup
                android:id="@+id/rgFirstPlayer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbPlayer1First"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Player 1"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:buttonTint="#1A1A1A"
                    android:checked="true"
                    android:gravity="center_vertical" />

                <RadioButton
                    android:id="@+id/rbPlayer2First"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Player 2"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:buttonTint="#1A1A1A"
                    android:gravity="center_vertical" />

                <RadioButton
                    android:id="@+id/rbCoinFlip"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Coin flip 🪙"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:buttonTint="#1A1A1A"
                    android:gravity="center_vertical" />

            </RadioGroup>

        </LinearLayout>

        <!-- ── SYMBOL SET ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="32dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYMBOL SET"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <Spinner
                android:id="@+id/spinnerSymbol"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_background"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:popupBackground="#FFFFFF" />

        </LinearLayout>

        <!-- ── START BUTTON ── -->
        <Button
            android:id="@+id/btnStartGame"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="START GAME"
            android:textSize="15sp"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A1A1A"
            android:layout_marginBottom="16dp" />

        <!-- ── HOW TO PLAY ── -->
        <Button
            android:id="@+id/btnHowToPlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="How to Play"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#E0E0E0"
            android:layout_marginBottom="40dp" />

    </LinearLayout>

</ScrollView>