<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPlayer1Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player 1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/tvPlayer1Score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Boards: 0"
                android:textSize="11sp"
                android:textColor="#9E9E9E" />

        </LinearLayout>

        <!-- Turn indicator in center -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvTurnLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TURN"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvCurrentTurn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:gravity="center" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvPlayer2Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player 2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/tvPlayer2Score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Boards: 0"
                android:textSize="11sp"
                android:textColor="#9E9E9E" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── SEND RULE BANNER ── -->
    <TextView
        android:id="@+id/tvSendRule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Play anywhere"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:background="#1A1A1A"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:gravity="center"
        android:letterSpacing="0.05" />

    <!-- ── MAIN BOARD (3x3 of mini boards) ── -->
    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <include android:id="@+id/board_00" layout="@layout/mini_board" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" />
        <include android:id="@+id/board_01" layout="@layout/mini_board" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" />
        <include android:id="@+id/board_02" layout="@layout/mini_board" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" />

    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <include android:id="@+id/board_10" layout="@layout/mini_board" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" />
        <include android:id="@+id/board_11" layout="@layout/mini_board" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" />
        <include android:id="@+id/board_12" layout="@layout/mini_board" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" />

    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <include android:id="@+id/board_20" layout="@layout/mini_board" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" />
        <include android:id="@+id/board_21" layout="@layout/mini_board" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" />
        <include android:id="@+id/board_22" layout="@layout/mini_board" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" />

    </LinearLayout>

</LinearLayout>