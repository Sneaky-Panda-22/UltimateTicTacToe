<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.UltimateTicTacToe" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.UltimateTicTacToe" parent="Base.Theme.UltimateTicTacToe" />

    <!-- Cell button style for mini board cells -->
    <style name="CellButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#1A1A1A</item>
        <item name="android:gravity">center</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
    <style name="RatingBarStyle" parent="Theme.AppCompat">
        <item name="colorAccent">#1A1A1A</item>
        <item name="android:colorControlNormal">#CCCCCC</item>
        <item name="android:colorControlActivated">#1A1A1A</item>
    </style>
</resources>